# =============================================================================
# BTP Usage Agent â Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# This file IS safe to commit to version control (no real secrets here).
# =============================================================================

# -----------------------------------------------------------------------------
# SAP BTP â Usage & Cost Management (UAS / Usage Data Management Service)
# -----------------------------------------------------------------------------

# Base URL of the BTP Usage Analytics Service (UAS) reporting endpoint.
# Default for eu10: https://uas-reporting.cfapps.eu10.hana.ondemand.com
BTP_UAS_URL=https://uas-reporting.cfapps.eu10.hana.ondemand.com

# XSUAA token endpoint for your BTP subaccount.
# Format: https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
BTP_AUTH_URL=https://xxx-ga.authentication.eu10.hana.ondemand.com/oauth/token

# OAuth2 client credentials for the UAS service instance binding.
BTP_CLIENT_ID=1
BTP_CLIENT_SECRET=1

# Your BTP subaccount GUID (visible in the BTP Cockpit Ã¢ÂÂ Subaccount Overview).
BTP_SUBACCOUNT_ID=5ad98679-e230-4e76-917a-b93b5508aa7b

# Your BTP global account GUID (visible in BTP Cockpit Ã¢ÂÂ Global Account Settings).
# Optional leave empty if you only query at subaccount level.
BTP_GLOBAL_ACCOUNT_ID=c0decf77trial



# -----------------------------------------------------------------------------
# LLM Backend â choose "joule" (default), "aicore", or "openai"
# -----------------------------------------------------------------------------
LLM_BACKEND=joule

# -- SAP AI Core (used when LLM_BACKEND=aicore or LLM_BACKEND=joule) ---------
# Option A: Paste the full service key JSON (takes priority, recommended)
# AICORE_SERVICE_KEY={"clientid":"...","clientsecret":"...","url":"...","serviceurls":{"AI_API_URL":"..."}}

# Option B: Individual fields from your AI Core BTP service key
AICORE_API_URL=https://api.ai.<region>.ml.hana.ondemand.com
AICORE_AUTH_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=<clientid-from-service-key>
AICORE_CLIENT_SECRET=<clientsecret-from-service-key>
AICORE_RESOURCE_GROUP=default

# Model deployed in AI Core Generative AI Hub (must be active)
AICORE_MODEL=gpt-4o

# Optional: pin to a specific deployment ID instead of model name
# AICORE_DEPLOYMENT_ID=<deployment-id>

# -- OpenAI / OpenAI-compatible endpoint (used when LLM_BACKEND=openai) ------
LLM_API_KEY=<your-openai-api-key>
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5001
