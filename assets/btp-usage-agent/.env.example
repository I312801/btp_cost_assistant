# =============================================================================
# BTP Usage Agent — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# This file IS safe to commit to version control (no real secrets here).
# =============================================================================

# -----------------------------------------------------------------------------
# SAP BTP — Usage & Cost Management (UAS / Usage Data Management Service)
# -----------------------------------------------------------------------------

# Base URL of the BTP Usage Analytics Service (UAS) reporting endpoint.
# Default for eu10: https://uas-reporting.cfapps.eu10.hana.ondemand.com
BTP_UAS_URL=https://uas-reporting.cfapps.eu10.hana.ondemand.com

# XSUAA token endpoint for your BTP subaccount.
# Format: https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
BTP_AUTH_URL=https://c0decf77trial-ga.authentication.eu10.hana.ondemand.com/oauth/token

# OAuth2 client credentials for the UAS service instance binding.
BTP_CLIENT_ID=sb-1ea14457-cc5b-421e-bef2-99d76bc6bc37!b681958|uas!b36585
BTP_CLIENT_SECRET=4162333a-80fd-4c32-9435-b353d691c1b8$maLYaGAHb0F91jiBp1sTd91x-2ABzLLZWrTQ51dRvlM=

# Your BTP subaccount GUID (visible in the BTP Cockpit â Subaccount Overview).
BTP_SUBACCOUNT_ID=5ad98679-e230-4e76-917a-b93b5508aa7b

# Your BTP global account GUID (visible in BTP Cockpit â Global Account Settings).
# Optional leave empty if you only query at subaccount level.
BTP_GLOBAL_ACCOUNT_ID=c0decf77trial



# -----------------------------------------------------------------------------
# LLM Backend — choose "joule" (default), "aicore", or "openai"
# -----------------------------------------------------------------------------
LLM_BACKEND=joule

# -- SAP AI Core Orchestration / Joule (used when LLM_BACKEND=joule) ---------
# The SAP AI Core Orchestration Service is the same engine that powers SAP Joule.
# The gen_ai_hub SDK reads the AICORE_* variables below automatically.
AICORE_AUTH_URL=https://<tenant>.authentication.<region>.hana.ondemand.com
AICORE_CLIENT_ID=<aicore-client-id>
AICORE_CLIENT_SECRET=<aicore-client-secret>
AICORE_API_URL=https://api.ai.<region>.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=default
# Model to use via Joule / Orchestration Service (must be deployed in AI Core)
JOULE_MODEL=gpt-4o

# -- SAP AI Core native client (used when LLM_BACKEND=aicore) ----------------
# Same AICORE_* credentials as above, plus:
AICORE_DEPLOYMENT_ID=<deployment-id>
AICORE_MODEL=gpt-4o

# -- OpenAI / OpenAI-compatible endpoint (used when LLM_BACKEND=openai) ------
LLM_API_KEY=<your-openai-api-key>
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5001
